# ============================================================
# Graça & Verdade — Variáveis de Ambiente
# ============================================================
# Copie este arquivo para .env e preencha os valores.
# NUNCA comite o arquivo .env real (está no .gitignore).
# ============================================================

# --- Formulário de Contato (Nodemailer + SMTP) ---
# Host do servidor SMTP
EMAIL_HOST=smtp.gmail.com

# Porta (587 = STARTTLS, 465 = SSL)
EMAIL_PORT=587

# Email remetente (login SMTP)
EMAIL_USER=seu-email@gmail.com

# Senha de app (NÃO é a senha da conta Google)
# Para gerar: https://myaccount.google.com/security > Verificação em duas etapas > Senhas de app
EMAIL_PASS=sua-senha-de-app

# Email que aparece no campo "From"
EMAIL_FROM=seu-email@gmail.com

# Email que recebe as mensagens do formulário
EMAIL_TO=seu-email@gmail.com

# --- Newsletter (futuro) ---
# Quando integrar com Mailchimp/ConvertKit, adicione a API key aqui:
# NEWSLETTER_API_KEY=
# NEWSLETTER_LIST_ID=
